-03":null,"content-03":null,"key-04":"timeFixed","content-04":0.1},{"mode":"head3","sttMode":3,"modeGroup":1,"contentName":"DIVA002","key-01":"cmd","content-01":"imageViewActionToID","key-02":"toID","content-02":"h_full","key-03":"img","content-03":"ADD_IMG04","key-04":null,"content-04":null},{"mode":"head3","sttMode":4,"modeGroup":1,"contentName":"DIVA003","key-01":"cmd","content-01":"divAction","key-02":"text","content-02":"ADD_ND04","key-03":null,"content-03":null,"key-04":null,"content-04":null},{"mode":"head3","sttMode":5,"modeGroup":1,"contentName":"DIVA004","key-01":"cmd","content-01":"divAction","key-02":null,"content-02":null,"key-03":null,"content-03":null,"key-04":null,"content-04":null},{"mode":"head3","sttMode":6,"modeGroup":1,"contentName":"DIVA005","key-01":"cmd","content-01":"imageViewActionToID","key-02":null,"content-02":null,"key-03":"img","content-03":"logo_brand-pvd.png","key-04":null,"content-04":null},{"mode":null,"sttMode":null,"modeGroup":null,"contentName":null,"key-01":null,"content-01":null,"key-02":null,"content-02":null,"key-03":null,"content-03":null,"key-04":null,"content-04":null},{"mode":"head4","sttMode":2,"modeGroup":1,"contentName":"DIVA001","key-01":"cmd","content-01":"divAction","key-02":"id","content-02":"h_full","key-03":null,"content-03":null,"key-04":"timeFixed","content-04":0.1},{"mode":"head4","sttMode":3,"modeGroup":1,"contentName":"DIVA002","key-01":"cmd","content-01":"imageViewActionToID","key-02":"toID","content-02":"h_full","key-03":"img","content-03":"ADD_IMG05","key-04":null,"content-04":null},{"mode":"head4","sttMode":4,"modeGroup":1,"contentName":"DIVA003","key-01":"cmd","content-01":"divAction","key-02":"text","content-02":"ADD_ND05","key-03":null,"content-03":null,"key-04":null,"content-04":null},{"mode":"head4","sttMode":5,"modeGroup":1,"contentName":"DIVA004","key-01":"cmd","content-01":"divAction","key-02":null,"content-02":null,"key-03":null,"content-03":null,"key-04":null,"content-04":null},{"mode":"head4","sttMode":6,"modeGroup":1,"contentName":"DIVA005","key-01":"cmd","content-01":"imageViewActionToID","key-02":null,"content-02":null,"key-03":"img","content-03":"logo_brand-pvd.png","key-04":null,"content-04":null}],[{"ADD_...":"Sheet 1","ADD_ND01":"Bạn đã từng nghe “connected speech” chưa?\n\nBạn nghe không hiểu tiếng Anh…\nkhông phải vì thiếu từ vựng\n\n👉 mà vì người ta chưa từng “nói rõ”\nnhư bạn nghĩ.","ADD_IMG01":"t2_1-1.png","ADD_ND02":"Bạn nghĩ người bản xứ nói kiểu này:\n\n👉 *What – are – you – doing?*\n\nNhưng thực tế bạn nghe thấy:\n\n👉 *Whatcha doin?*\n\n💥 Không phải họ nói sai\n👉 họ đang nói theo cách **tự nhiên**","ADD_IMG02":"t2_1-2.png","ADD_ND03":"Đây gọi là **connected speech**\n— khi các từ **dính lại với nhau**:\n\n* *want to* → **wanna**\n* *going to* → **gonna**\n* *did you* → **didja**\n\n👉 Họ không nói từng từ\n👉 Họ nói theo **dòng âm thanh**","ADD_IMG03":"t2_1-3.png","ADD_ND04":"Vấn đề là:\n\nBạn đang **nghe từng chữ**\nTrong khi họ đang **nói theo âm**\n\n👉 Não bạn không nhận ra\n👉 Và bạn nghĩ mình “nghe kém”","ADD_IMG04":"t2_1-4.png","ADD_ND05":"Bạn không nghe kém.\n👉 Bạn chỉ chưa quen với âm thanh thật.\n\nTừ hôm nay:\n\n* Đừng cố bắt từng từ\n* Hãy nghe cả cụm, cả nhịp nói\n\n🔥 Muốn hiểu người bản xứ?\nHãy học cách họ **thực sự nói**","ADD_IMG05":"t2_1-5.png"},{"ADD_...":"Sheet 2","ADD_ND01":"Bạn đã từng nghe “shadowing” chưa?\n\nBạn học tiếng Anh cả năm…\nnhưng vẫn không nói được\n\n👉 Có thể vì bạn chưa từng\nluyện theo cách này.","ADD_IMG01":"t2_2-1.png","ADD_ND02":"Bạn đang học kiểu quen thuộc:\n\n* Học từ vựng\n* Học ngữ pháp\n* Nghe rồi… để đó\n\n👉 Nhưng bạn **không nói lại**\n\n💥 Và đó là lý do\nbạn không thể phản xạ","ADD_IMG02":"t2_2-2.png","ADD_ND03":"Shadowing là gì?\n\n👉 Nghe → lặp lại NGAY lập tức\n👉 Bắt chước cả: âm, nhịp, ngữ điệu\n\nKhông dừng – không dịch\n👉 Chỉ “bám sát” người nói","ADD_IMG03":"t2_2-3.png","ADD_ND04":"Khi bạn shadowing:\n\n* Tai quen với âm thật\n* Miệng quen cách phát âm\n* Não hình thành phản xạ\n\n👉 Nghe – nói trở thành **một**","ADD_IMG04":"t2_2-4.png","ADD_ND05":"Bạn không nói được\nkhông phải vì bạn thiếu kiến thức\n\n👉 Mà vì bạn chưa luyện phản xạ\n\nHãy thử mỗi ngày:\n\n* 2–3 phút shadowing\n* Lặp lại nhiều lần\n\n🔥 Bạn sẽ bất ngờ với sự tiến bộ","ADD_IMG05":"t2_2-5.png"},{"ADD_...":"Sheet 3","ADD_ND01":"Bạn đã từng nghe “muscle memory” chưa?\n\nBạn không nói được tiếng Anh…\n👉 Không phải vì bạn không biết\n\nMà vì…\n👉 **miệng bạn chưa từng được luyện**","ADD_IMG01":"t2_3-1.png","ADD_ND02":"Bạn có nhận ra không?\n\n* Bạn hiểu khi đọc\n* Bạn biết khi học\n* Nhưng khi nói… lại đứng hình\n\n👉 Vì bạn đang học trong đầu\nchứ chưa luyện bằng cơ thể","ADD_IMG02":"t2_3-2.png","ADD_ND03":"Muscle memory = trí nhớ của cơ\n\nKhi bạn lặp lại một âm đủ nhiều:\n👉 Lưỡi biết đặt ở đâu\n👉 Miệng tự bật ra\n\nKhông cần nghĩ\n👉 vẫn nói được","ADD_IMG03":"t2_3-3.png","ADD_ND04":"Giống như:\n\n* Bạn không cần nghĩ khi đánh máy\n* Không cần nghĩ khi đi xe đạp\n\n👉 Vì cơ thể đã “nhớ”\n\nTiếng Anh cũng vậy:\n👉 Không luyện → không quen\n👉 Không quen → không nói được","ADD_IMG04":"t2_3-4.png","ADD_ND05":"Bạn không nói kém\n👉 Bạn chỉ chưa luyện đúng cách\n\nTừ hôm nay:\n\n* Nói to\n* Lặp lại nhiều lần\n* Đừng chỉ học bằng mắt\n\n🔥 Khi miệng quen → bạn sẽ nói trôi chảy","ADD_IMG05":"t2_3-5.png"},{"ADD_...":"Sheet 4","ADD_ND01":"Bạn đã từng nghe “spaced repetition” chưa?\n\nBạn học từ vựng hôm nay…\nmai quên gần hết\n\n👉 Không phải vì bạn kém trí nhớ\n👉 Mà vì bạn đang học **sai nhịp của não**","ADD_IMG01":"t2_4-1.png","ADD_ND02":"Bạn thường học kiểu này:\n\n* Học một lần thật nhiều\n* Lặp lại ngay sau đó\n* Rồi… bỏ luôn\n\n👉 Não bạn nghĩ: “Không cần giữ lại”\n\n💥 Và bạn quên rất nhanh","ADD_IMG02":"t2_4-2.png","ADD_ND03":"Spaced repetition = ôn lặp có khoảng cách\n\n👉 Ôn lại trước khi bạn quên hẳn\n👉 Mỗi lần cách nhau xa hơn:\n\n* Ngày 1 → học\n* Ngày 2 → ôn\n* Ngày 4 → ôn\n* Ngày 7 → ôn\n\n👉 Não hiểu: “Cái này quan trọng”","ADD_IMG03":"t2_4-3.png","ADD_ND04":"Tại sao cách này hiệu quả?\n\n* Não nhớ tốt hơn khi “suýt quên”\n* Mỗi lần ôn → dấu ấn sâu hơn\n* Không cần học nhiều… vẫn nhớ lâu\n\n👉 Học ít hơn\n👉 Nhưng thông minh hơn","ADD_IMG04":"t2_4-4.png","ADD_ND05":"Bạn không cần trí nhớ tốt hơn\n👉 Bạn cần cách ôn đúng hơn\n\nTừ hôm nay:\n\n* Đừng học dồn\n* Hãy ôn đúng thời điểm\n\n🔥 Nhớ lâu không phải do may mắn\n👉 Mà do chiến lược","ADD_IMG05":"t2_4-5.png"},{"ADD_...":"Sheet 5","ADD_ND01":"Bạn đã từng nghe “active recall” chưa?\n\nBạn nghĩ mình đã học xong…\n👉 Nhưng thật ra bạn chưa từng **thử nhớ**","ADD_IMG01":"t2_5-1.png","ADD_ND02":"Bạn học theo cách quen thuộc:\n\n* Đọc lại tài liệu\n* Xem lại ghi chú\n* Highlight rất nhiều\n\n👉 Bạn thấy “quen mắt”\n👉 Và nghĩ rằng mình “đã nhớ”","ADD_IMG02":"t2_5-2.png","ADD_ND03":"Active recall = tự kéo kiến thức ra khỏi não\n\n👉 Không nhìn tài liệu\n👉 Tự hỏi – tự trả lời\n\nVí dụ:\n\n* Nghĩa của từ này là gì?\n* Câu này nói sao bằng tiếng Anh?\n\n👉 Nếu không nhớ được → nghĩa là bạn chưa học xong","ADD_IMG03":"t2_5-3.png","ADD_ND04":"Tại sao cách này hiệu quả?\n\n* Não phải “hoạt động” để nhớ\n* Mỗi lần nhớ → dấu ấn mạnh hơn\n* Học ít nhưng sâu hơn\n\n👉 Nhớ thật ≠ nhìn lại\n👉 Nhớ thật = tự gọi ra","ADD_IMG04":"t2_5-4.png","ADD_ND05":"Bạn không học kém\n👉 Bạn chỉ đang học “thụ động”\n\nTừ hôm nay:\n\n* Đóng sách lại\n* Tự hỏi bản thân\n* Cố nhớ trước khi xem lại\n\n🔥 Nếu bạn không nhớ được…\n👉 Đó mới là lúc bạn bắt đầu học thật sự","ADD_IMG05":"t2_5-5.png"}],[{"Hoàn thiện bảng sau theo mô tả (chỉ hoàn thiện dòng có dữ liệu)":null,"transitionName":"slideToTheRight_100","description":"Slide từ trái vào (element di chuyển từ -100% sang 0)","isLoopDefault":false,"useLinearProgressDefault":false,"delayState":null,"at-01":0,"keyframes-01":"{\"opacity\": 1, \"translateX\": -100}","at-02":1,"keyframes-02":"{\"opacity\": 1, \"translateX\": 0}","at-03":null,"keyframes-03":null,"at-04":null,"keyframes-04":null,"at-05":null,"keyframes-05":null},{"Hoàn thiện bảng sau theo mô tả (chỉ hoàn thiện dòng có dữ liệu)":null,"tran